{
  "extends": "airbnb-base",
  "parserOptions": {
    "ecmaVersion": 2020
  },
  "rules": {
    "no-console": "off",

    "no-underscore-dangle": [
      "error",
      {
        "allow": ["_id"]
      }
    ],

    "no-unused-vars": [
      "error",
      {
        "argsIgnorePattern": "^next$"
      }
    ]
  }
}
